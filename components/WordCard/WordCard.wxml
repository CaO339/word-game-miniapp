<!-- WordCard 组件 -->
<view class="word-card">
  <!-- 单词 -->
  <view class="word-section">
    <text class="word">{{word.word || word.english}}</text>
  </view>
  
  <!-- 词性 -->
  <view class="pos-section" wx:if="{{word.partOfSpeech}}">
    <text class="pos-label">词性</text>
    <text class="pos-value">{{word.partOfSpeech}}</text>
  </view>
  
  <!-- 音标 -->
  <view class="phonetic-section" wx:if="{{word.phonetic}}">
    <text class="phonetic-label">音标</text>
    <text class="phonetic-value">{{word.phonetic}}</text>
  </view>
  
  <!-- 释义 -->
  <view class="definition-section" wx:if="{{word.meaning || word.chinese}}">
    <text class="section-label">释义</text>
    <text class="definition-content">{{word.meaning || word.chinese}}</text>
  </view>
  
  <!-- 搭配 -->
  <view class="collocations-section" wx:if="{{word.collocation}}">
    <text class="section-label">搭配</text>
    <view class="collocations-list">
      <text 
        class="collocation-item" 
        wx:for="{{collocationList}}" 
        wx:key="index"
      >• {{item}}</text>
    </view>
  </view>
  
  <!-- 例句 -->
  <view class="example-section" wx:if="{{word.example}}">
    <text class="section-label">例句</text>
    <text class="example-content">{{word.example}}</text>
    <text class="example-translation" wx:if="{{word.translation}}">{{word.translation}}</text>
  </view>
  
  <!-- 词根 -->
  <view class="root-section" wx:if="{{word.root}}">
    <text class="section-label">词根</text>
    <text class="root-content">{{word.root}}</text>
  </view>
</view>