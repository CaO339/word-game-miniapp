/* WordCard 组件样式 */
.word-card {
  padding: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  min-height: 400rpx;
}

/* 发音按钮区域 */
.audio-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.audio-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.audio-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.audio-btn .flag {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.audio-btn .label {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 播放错误提示 */
.audio-error {
  text-align: center;
  font-size: 24rpx;
  color: #ff4757;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 71, 87, 0.1);
  border-radius: 8rpx;
}

/* 单词区域 */
.word-section {
  text-align: center;
  margin-bottom: 16rpx;
}

.word {
  font-size: 56rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
}

/* 音标区域 */
.phonetic-section {
  text-align: center;
  margin-bottom: 24rpx;
}

.phonetic-value {
  font-size: 28rpx;
  color: #666666;
  font-style: italic;
}

/* 答案内容区域 */
.answer-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 标签样式 */
.section-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #4A90E2;
  margin-bottom: 8rpx;
}

/* 词性区域 */
.pos-section {
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.pos-value {
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: 500;
}

/* 释义区域 */
.definition-section {
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.definition-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
}

/* 搭配区域 */
.collocations-section {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.collocations-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.collocation-item {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
  padding-left: 8rpx;
}

/* 提示区域 */
.hint-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
}