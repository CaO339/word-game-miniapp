/* WordCard 组件样式 */

/* 主卡片容器 */
.word-card {
  width: 88%;
  max-width: 680rpx;
  margin: 0 auto;
  padding: 40rpx 32rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  min-height: 300rpx;
  box-sizing: border-box;
}

/* 单词区域 */
.word-section {
  text-align: center;
  margin-bottom: 24rpx;
}

.word {
  font-size: 56rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
  line-height: 1.4;
}

/* 音频按钮区域 */
.audio-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.audio-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  padding: 0;
}

.audio-btn::after {
  border: none;
}

.button-hover {
  opacity: 0.85;
  transform: scale(0.96);
}

.audio-btn .flag {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.audio-btn .label {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 音频错误提示 */
.audio-error {
  text-align: center;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 24rpx;
  color: #ff4757;
  padding: 8rpx 16rpx;
  background: rgba(255, 71, 87, 0.1);
  border-radius: 8rpx;
}

/* 答案内容区域 */
.answer-content {
  animation: fadeIn 0.3s ease;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #E0E0E0;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 标签样式 */
.section-label {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #4A90E2;
  margin-bottom: 8rpx;
}

/* 词性区域 */
.pos-section {
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: #f0f4ff;
  border-radius: 10rpx;
}

.pos-value {
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: 600;
}

/* 释义区域 */
.definition-section {
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: #f0f4ff;
  border-radius: 10rpx;
}

.definition-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
}

/* 搭配区域 */
.collocations-section {
  margin-top: 16rpx;
}

.collocations-list {
  margin-top: 8rpx;
}

.collocation-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
  padding: 8rpx 12rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

.collocation-bullet {
  font-size: 24rpx;
  color: #667eea;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.collocation-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.5;
  word-break: break-word;
}

/* 提示区域 */
.hint-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  margin-top: 20rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}
