/* 词库浏览页面样式 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部统计区域 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: #667eea;
  padding: 30rpx 20rpx;
  color: #ffffff;
}

.stats-bar .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-bar .stat-number {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stats-bar .stat-number.learned {
  color: #38ef7d;
}

.stats-bar .stat-number.pending {
  color: #ffd700;
}

.stats-bar .stat-number.not-learned {
  color: rgba(255, 255, 255, 0.7);
}

.stats-bar .stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-bar .stat-divider {
  width: 2rpx;
  height: 50rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 搜索框 */
.search-section {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.clear-icon {
  font-size: 28rpx;
  color: #999999;
  padding: 10rpx;
}

/* 状态筛选标签 */
.filter-section {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.filter-tag {
  padding: 12rpx 30rpx;
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.filter-tag.active {
  color: #ffffff;
  background-color: #667eea;
}

.filter-tag.learned.active {
  background-color: #38ef7d;
  color: #1a5c4a;
}

.filter-tag.pending.active {
  background-color: #ffd700;
  color: #8b6914;
}

.filter-tag.not-learned.active {
  background-color: #999999;
}

/* 单词列表 */
.word-list {
  flex: 1;
  padding: 20rpx 30rpx;
  height: calc(100vh - 400rpx);
}

/* 单词卡片 */
.word-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #999999;
  transition: all 0.3s ease;
}

.word-card.learned {
  border-left-color: #38ef7d;
}

.word-card.pendingReview {
  border-left-color: #ffd700;
}

.word-card.notLearned {
  border-left-color: #999999;
}

.word-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.word-english {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background-color: #f5f5f5;
  color: #666666;
}

.status-tag.learned {
  background-color: rgba(56, 239, 125, 0.2);
  color: #1a5c4a;
}

.status-tag.pendingReview {
  background-color: rgba(255, 215, 0, 0.2);
  color: #8b6914;
}

.status-tag.notLearned {
  background-color: rgba(153, 153, 153, 0.2);
  color: #666666;
}

.word-chinese {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.back-btn:active {
  transform: translateX(-50%) scale(0.98);
  opacity: 0.9;
}
