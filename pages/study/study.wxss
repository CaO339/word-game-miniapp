/* 学习页面样式 - 统一风格 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.progress {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 学习统计栏 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 90%;
  max-width: 400rpx;
  background-color: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 20rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 单词卡片 */
.word-card {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 60rpx;
  position: relative;
  min-height: 600rpx;
}

/* 收藏按钮 */
.collect-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.collect-btn text {
  font-size: 36rpx;
}

.collect-btn .collected {
  color: #ff4757;
}

.word-english {
  font-size: 72rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.word-phonetic {
  font-size: 32rpx;
  color: #888888;
  margin-bottom: 20rpx;
  font-style: italic;
}

.word-part-of-speech {
  font-size: 28rpx;
  color: #667eea;
  background-color: rgba(102, 126, 234, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

/* 答案区域 */
.answer-section {
  width: 100%;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  margin-top: 20rpx;
}

.answer-section.show {
  opacity: 1;
  transform: translateY(0);
}

/* 答案项通用样式 */
.word-meaning,
.word-example,
.word-translation,
.word-collocation,
.word-root {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
}

.word-meaning .label,
.word-example .label,
.word-translation .label,
.word-collocation .label,
.word-root .label {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.word-meaning .content {
  font-size: 36rpx;
  color: #333333;
  font-weight: 500;
}

.word-example .content {
  font-size: 28rpx;
  color: #555555;
  font-style: italic;
}

.word-translation .content {
  font-size: 28rpx;
  color: #666666;
}

.word-collocation .content {
  font-size: 26rpx;
  color: #777777;
}

.word-root .content {
  font-size: 26rpx;
  color: #888888;
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 30rpx;
}

/* 按钮组 */
.btn-group {
  width: 90%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 认识/不认识按钮组 */
.result-btn-group {
  display: flex;
  justify-content: space-between;
  width: 100%;
  gap: 30rpx;
}

.result-btn-group .btn {
  flex: 1;
}

/* 通用按钮样式 */
.btn {
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 显示答案按钮 - 主色调 */
.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

/* 认识按钮 - 成功色调 */
.btn-success {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #ffffff;
}

/* 不认识按钮 - 危险色调 */
.btn-danger {
  background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
  color: #ffffff;
}

/* 返回首页链接 */
.home-link {
  margin-top: 40rpx;
}

.link-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: underline;
}

.link-text:active {
  opacity: 0.6;
}