/* 学习页面样式 */

.container {
  /* 使用flex布局使内容垂直居中 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 单词卡片 */
.word-card {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 60rpx;
}

.word-english {
  font-size: 72rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 40rpx;
  letter-spacing: 4rpx;
}

.word-chinese {
  font-size: 48rpx;
  color: #666666;
  /* 默认隐藏答案 */
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
}

.word-chinese.show {
  opacity: 1;
  transform: translateY(0);
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 30rpx;
}

/* 按钮组 */
.btn-group {
  width: 90%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 通用按钮样式 */
.btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  /* 移除按钮默认边框 */
  border: none;
}

/* 显示答案按钮 - 主色调 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 下一个单词按钮 - 成功色调 */
.btn-success {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #ffffff;
}

.btn-success:active {
  opacity: 0.8;
}

/* 学习完成按钮 - 警告色调 */
.btn-warning {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
}

.btn-warning:active {
  opacity: 0.8;
}
