<!--学习页面 WXML-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">WordMaster</text>
    <text class="subtitle">{{wordListName}}</text>
    <text class="progress">已学习 {{learnedCount}}/{{totalWords}}</text>
  </view>

  <!-- 每日目标显示 -->
  <view class="target-banner {{targetIsCompleted ? 'completed' : ''}}">
    <text class="target-text">{{targetIsCompleted ? '🎯 今日目标已完成' : '📍 今日目标: ' + targetTodayNewCount + '/' + target}}</text>
  </view>

  <!-- 学习统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{todayCount}}</text>
      <text class="stat-label">今日练习</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{totalCount}}</text>
      <text class="stat-label">已学单词</text>
    </view>
  </view>

  <!-- 单词卡片 -->
  <view class="word-card">
    <!-- 收藏按钮 -->
    <view class="collect-btn" bindtap="toggleCollect">
      <text class="{{isCollected ? 'collected' : ''}}">{{isCollected ? '❤️' : '🤍'}}</text>
    </view>
    
    <!-- 英文单词 -->
    <view class="word-english">{{currentWord.word || currentWord.english}}</view>
    
    <!-- 音标 -->
    <view class="word-phonetic">{{currentWord.phonetic}}</view>
    
    <!-- 词性 -->
    <view class="word-part-of-speech">{{currentWord.partOfSpeech}}</view>

    <!-- 答案区域（点击显示答案后显示） -->
    <view class="answer-section {{showAnswer ? 'show' : ''}}">
      <!-- 中文释义 -->
      <view class="word-meaning">
        <text class="label">释义</text>
        <text class="content">{{currentWord.meaning || currentWord.chinese}}</text>
      </view>
      
      <!-- 例句 -->
      <view class="word-example">
        <text class="label">例句</text>
        <text class="content">{{currentWord.example}}</text>
      </view>
      
      <!-- 例句翻译 -->
      <view class="word-translation">
        <text class="label">翻译</text>
        <text class="content">{{currentWord.translation}}</text>
      </view>
      
      <!-- 常见搭配 -->
      <view class="word-collocation">
        <text class="label">搭配</text>
        <text class="content">{{currentWord.collocation}}</text>
      </view>
      
      <!-- 词根词缀 -->
      <view class="word-root">
        <text class="label">词根</text>
        <text class="content">{{currentWord.root}}</text>
      </view>
    </view>

    <!-- 提示文字 -->
    <view class="hint-text" wx:if="{{!showAnswer}}">
      点击下方按钮显示答案
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="btn-group">
    <!-- 显示答案按钮 -->
    <button
      class="btn btn-primary"
      bindtap="showAnswer"
      wx:if="{{!showAnswer}}">
      显示答案
    </button>

    <!-- 认识/不认识按钮组 -->
    <view class="result-btn-group" wx:if="{{showResultButtons}}">
      <button
        class="btn btn-success"
        bindtap="markKnown">
        认识
      </button>
      <button
        class="btn btn-danger"
        bindtap="markUnknown">
        不认识
      </button>
    </view>
  </view>

  <!-- 返回首页 -->
  <view class="home-link">
    <text bindtap="goHome" class="link-text">返回首页</text>
  </view>
</view>