<!--学习页面 WXML-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">WordMaster</text>
    <text class="subtitle">{{wordListName}}</text>
    <text class="progress">已学习 {{learnedCount}}/{{totalWords}}</text>
  </view>

  <!-- 学习统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{todayCount}}</text>
      <text class="stat-label">今日练习</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{totalCount}}</text>
      <text class="stat-label">已学单词</text>
    </view>
  </view>

  <!-- 单词卡片 -->
  <view class="word-card">
    <!-- 英文单词 -->
    <view class="word-english">{{currentWord.english}}</view>

    <!-- 中文释义（点击显示答案后显示） -->
    <view class="word-chinese {{showAnswer ? 'show' : ''}}">
      {{currentWord.chinese}}
    </view>

    <!-- 提示文字 -->
    <view class="hint-text" wx:if="{{!showAnswer}}">
      点击下方按钮显示答案
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="btn-group">
    <!-- 显示答案按钮 -->
    <button
      class="btn btn-primary"
      bindtap="showAnswer"
      wx:if="{{!showAnswer}}">
      显示答案
    </button>

    <!-- 认识/不认识按钮组 -->
    <view class="result-btn-group" wx:if="{{showResultButtons}}">
      <button
        class="btn btn-success"
        bindtap="markKnown">
        认识
      </button>
      <button
        class="btn btn-danger"
        bindtap="markUnknown">
        不认识
      </button>
    </view>
  </view>

  <!-- 返回首页 -->
  <view class="home-link">
    <text bindtap="goHome" class="link-text">返回首页</text>
  </view>
</view>
