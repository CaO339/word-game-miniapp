<!--错题本页面的 WXML-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">错题本</text>
    <text class="subtitle">共 {{mistakeCount}} 个待巩固单词</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <text class="empty-icon">📝</text>
    <text class="empty-title">暂无错题</text>
    <text class="empty-desc">学习时点击"不认识"的单词会自动加入错题本</text>
    <button class="start-btn" bindtap="goHome">去学习</button>
  </view>

  <!-- 错题列表 -->
  <view class="word-list" wx:else>
    <view 
      class="word-item" 
      wx:for="{{mistakeWords}}" 
      wx:key="id"
      data-id="{{item.id}}">
      
      <view class="word-info" bindtap="studyWord" data-id="{{item.id}}">
        <text class="word-english">{{item.english}}</text>
        <text class="word-chinese">{{item.chinese}}</text>
      </view>
      
      <view class="word-actions">
        <text class="remove-btn" bindtap="removeMistake" data-id="{{item.id}}">✓</text>
      </view>
    </view>
  </view>

  <!-- 返回按钮 -->
  <view class="footer" wx:if="{{!isEmpty}}">
    <button class="back-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
