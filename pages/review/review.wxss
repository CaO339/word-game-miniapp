/* 复习页面样式 */

.container {
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 进度条区域 */
.progress-section {
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #ffffff;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 复习完成区域 */
.completed-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.completed-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.completed-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.completed-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 50rpx;
}

.home-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #ffffff;
  border: none;
}

/* 没有待复习单词区域 */
.no-pending-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-pending-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.no-pending-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.no-pending-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 50rpx;
  text-align: center;
}

/* 单词卡片区域 */
.card-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.word-card {
  width: 90%;
  max-width: 600rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

/* 单词区域 */
.word-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.word {
  font-size: 64rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 15rpx;
}

.phonetic {
  font-size: 28rpx;
  color: #999999;
}

/* 释义区域 */
.meaning-section {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background-color: rgba(79, 172, 254, 0.1);
  border-radius: 20rpx;
}

.meaning {
  font-size: 36rpx;
  color: #333333;
}

/* 显示答案按钮 */
.show-answer-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  border: none;
}

.show-answer-btn:active {
  transform: scale(0.98);
}

/* 结果按钮区域 */
.result-buttons {
  display: flex;
  justify-content: space-between;
}

.result-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.result-btn:active {
  transform: scale(0.98);
}

.known-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #ffffff;
  margin-right: 20rpx;
}

.unknown-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
  margin-left: 20rpx;
}

/* 返回首页链接 */
.home-link {
  text-align: center;
  margin-top: 60rpx;
}

.home-link text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}
