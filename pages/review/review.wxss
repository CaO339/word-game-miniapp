/* 复习页面样式 - 统一风格 */

.container {
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  /* 统一主色调：紫色渐变 */
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 进度条区域 */
.progress-section {
  margin-bottom: 40rpx;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700 0%, #ff6b6b 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 复习完成区域 */
.completed-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.completed-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.completed-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.completed-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 50rpx;
}

.home-btn {
  width: 300rpx;
  height: 100rpx;
  line-height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

/* 没有待复习单词区域 */
.no-pending-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-pending-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.no-pending-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.no-pending-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 50rpx;
  text-align: center;
}

/* 单词卡片区域 */
.card-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 单词卡片容器 */
.word-card-wrapper {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

/* 未显示答案时只显示单词 */
.word-only {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
}

.word-only .word {
  font-size: 72rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
}

.word-only .hint-text {
  font-size: 26rpx;
  color: #999999;
}

/* 显示答案按钮 */
.show-answer-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
  margin-top: 20rpx;
}

.show-answer-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 结果按钮区域 */
.result-buttons {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  margin-top: 20rpx;
}

.result-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

.result-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.known-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #ffffff;
}

.unknown-btn {
  background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
  color: #ffffff;
}

/* 返回首页链接 */
.home-link {
  text-align: center;
  margin-top: 60rpx;
}

.home-link text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: underline;
}

.home-link text:active {
  opacity: 0.6;
}
