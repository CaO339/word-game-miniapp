<!--收藏页面 WXML-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">我的收藏</text>
    <text class="subtitle">共 {{collectedCount}} 个收藏单词</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <text class="empty-icon">🤍</text>
    <text class="empty-title">暂无收藏</text>
    <text class="empty-desc">在学习时点击心形按钮收藏单词</text>
    <button class="start-btn" bindtap="goHome">去学习</button>
  </view>

  <!-- 收藏列表 -->
  <view class="word-list" wx:else>
    <view 
      class="word-item" 
      wx:for="{{collectedWords}}" 
      wx:key="id"
      data-id="{{item.id}}">
      
      <view class="word-info" bindtap="studyWord" data-id="{{item.id}}">
        <text class="word-english">{{item.english}}</text>
        <text class="word-chinese">{{item.chinese}}</text>
      </view>
      
      <view class="word-actions">
        <text class="uncollect-btn" bindtap="uncollectWord" data-id="{{item.id}}">❤️</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="footer" wx:if="{{!isEmpty}}">
    <button class="export-btn" bindtap="exportPdf">📄 导出收藏PDF</button>
    <button class="back-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
