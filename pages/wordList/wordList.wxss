/* wordList.wxss - 词库单词浏览页面样式 */

.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 自定义导航栏 */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.navbar-left {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.navbar-right {
  width: 60rpx;
}

/* 搜索区域 */
.search-section {
  padding: 120rpx 30rpx 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 词库信息 */
.library-info {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx 20rpx;
}

.library-name {
  font-size: 28rpx;
  color: #666;
}

.word-count {
  font-size: 26rpx;
  color: #999;
}

/* 字母索引 */
.alphabet-index {
  position: fixed;
  right: 20rpx;
  top: 200rpx;
  bottom: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 50;
}

.alphabet-item {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  border-radius: 50%;
  margin: 4rpx 0;
}

.alphabet-item:active {
  background-color: #667eea;
  color: #fff;
}

/* 字母提示 */
.letter-toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  z-index: 200;
}

/* 单词列表 */
.word-list {
  height: calc(100vh - 220rpx);
  padding: 0 30rpx;
}

.word-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.letter-header {
  background: #f5f5f5;
  padding: 20rpx 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  position: sticky;
  top: 0;
  z-index: 10;
}

.word-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.03);
}

.word-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.word-english {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.word-phonetic {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.word-meaning {
  margin-bottom: 15rpx;
}

.meaning-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.word-part {
  display: flex;
}

.part-tag {
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}