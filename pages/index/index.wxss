/* 首页样式 */

.container {
  /* 使用flex布局使内容垂直居中 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 20rpx;
  /* 添加阴影效果 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 4rpx;
}

/* 统计卡片区域 */
.stats-section {
  width: 90%;
  max-width: 500rpx;
  margin-bottom: 60rpx;
}

.stats-card {
  background-color: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

/* 等级行 */
.level-row {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.level-badge {
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(255, 215, 0, 0.3);
}

.level-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b6914;
}

/* 每日目标行 */
.target-row {
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.target-item {
  display: flex;
  align-items: center;
  background-color: rgba(102, 126, 234, 0.2);
  padding: 16rpx 30rpx;
  border-radius: 25rpx;
  transition: all 0.3s ease;
}

.target-item.completed {
  background-color: rgba(17, 153, 142, 0.2);
}

.target-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.target-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.target-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.target-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.target-item.completed .target-value {
  color: #38ef7d;
}

/* 经验值行 */
.xp-row {
  margin-bottom: 30rpx;
}

.xp-info {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.xp-current {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.xp-separator {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 8rpx;
}

.xp-max {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 经验值进度条容器 */
.xp-bar-container {
  width: 100%;
  height: 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
}

/* 经验值进度条填充 */
.xp-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700 0%, #ff6b6b 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 统计行 */
.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 分隔线 */
.stat-divider {
  height: 2rpx;
  background-color: rgba(255, 255, 255, 0.2);
  margin-bottom: 30rpx;
}

/* 打卡行 */
.checkin-row {
  display: flex;
  justify-content: center;
}

.checkin-item {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
}

.checkin-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.checkin-content {
  display: flex;
  flex-direction: column;
}

.checkin-days {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.checkin-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 待复习行 */
.review-row {
  display: flex;
  justify-content: center;
}

.review-item {
  display: flex;
  align-items: center;
  background-color: rgba(255, 215, 0, 0.2);
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
}

.review-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.review-content {
  display: flex;
  flex-direction: column;
}

.review-count {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
}

.review-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 收藏和错题区域 */
.extra-row {
  display: flex;
  justify-content: space-around;
}

.extra-item {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  padding: 15rpx 30rpx;
  border-radius: 20rpx;
}

.extra-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.extra-content {
  display: flex;
  flex-direction: column;
}

.extra-count {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.extra-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 欢迎文字区域 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.description {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 按钮区域 */
.btn-section {
  width: 80%;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 开始学习按钮 */
.start-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f8f8 100%);
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  border: none;
  /* 添加阴影效果 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 20rpx;
}

.start-btn:active {
  /* 点击时缩小效果 */
  transform: scale(0.98);
  opacity: 0.9;
}

/* 开始复习按钮 */
.review-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  /* 添加阴影效果 */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 20rpx;
}

/* 学习统计按钮 */
.stats-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  border: none;
  /* 添加阴影效果 */
  box-shadow: 0 10rpx 30rpx rgba(79, 172, 254, 0.3);
}

.review-btn:active {
  /* 点击时缩小效果 */
  transform: scale(0.98);
  opacity: 0.9;
}
