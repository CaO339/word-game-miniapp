<!--首页 WXML-->
<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">WM</view>
    <text class="app-name">WordMaster</text>
  </view>

  <!-- 当前词库显示区域 -->
  <view class="current-library-section">
    <view class="current-library-label">当前词库</view>
    <view class="current-library-value">
      <text class="library-icon">📚</text>
      <text class="library-name">{{currentLibrary}}</text>
    </view>
  </view>

  <!-- 词库选择区域 -->
  <view class="library-section">
    <view class="library-header">
      <view class="library-title">选择词库</view>
      <view class="library-more" bindtap="goToLibrary">
        <text>管理</text>
        <text class="more-icon">→</text>
      </view>
    </view>

    <!-- 系统词库 -->
    <view class="system-library-section">
      <view class="system-library-title">📖 系统词库</view>
      <view class="library-list">
        <view 
          wx:for="{{fixedLibraries}}" 
          wx:key="key"
          class="library-item {{selectedLibrary === item.key ? 'active' : ''}}" 
          bindtap="switchLibrary" 
          data-library="{{item.key}}" 
        >
          <text class="library-name">{{item.name}}</text>
          <text class="library-desc">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 自定义词库 -->
    <view wx:if="{{customLibraries.length > 0}}" class="custom-library-section">
      <view class="custom-library-title">📁 自定义词库</view>
      <view class="library-list">
        <view 
          wx:for="{{customLibraries}}" 
          wx:key="key"
          class="library-item custom {{selectedLibrary === item.key ? 'active' : ''}}" 
          bindtap="switchLibrary" 
          data-library="{{item.key}}" 
        >
          <text class="library-name">{{item.name}}</text>
          <text class="library-desc">{{item.wordCount}} 个单词</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 统计卡片区域 -->
  <view class="stats-section">
    <view class="stats-card">
      <!-- 每日目标区域 -->
      <view class="target-row">
        <view class="target-item {{targetIsCompleted ? 'completed' : ''}}" bindtap="changeTarget">
          <view class="target-icon">{{targetIsCompleted ? '🎯' : '📍'}}</view>
          <view class="target-content">
            <text class="target-label">今日目标</text>
            <text class="target-value">{{targetIsCompleted ? '已完成' : targetTodayNewCount + '/' + target}}</text>
          </view>
          <view class="target-edit-icon">✏️</view>
        </view>
      </view>

      <view class="stat-divider"></view>

      <!-- 学习进度区域 -->
      <view class="progress-row">
        <view class="progress-item" bindtap="viewLibrary">
          <view class="progress-icon">📚</view>
          <view class="progress-content">
            <text class="progress-label">词库进度</text>
            <text class="progress-value">{{learnedCount}}/{{totalWords}}</text> 
          </view>
        </view>
        <view class="progress-info">
          <text class="progress-remaining">剩余 {{remainingCount}} 个单词</text>
        </view>
      </view>

      <view class="stat-divider"></view>

      <!-- 等级显示 -->
      <view class="level-row">
        <view class="level-badge">
          <text class="level-text">Lv{{currentLevel}}</text>
        </view>
      </view>

      <!-- 经验值进度条 -->
      <view class="xp-row">
        <view class="xp-info">
          <text class="xp-current">{{currentXp}}</text>
          <text class="xp-separator">/</text>
          <text class="xp-max">{{maxXp}}</text>
        </view>
        <view class="xp-bar-container">
          <view class="xp-bar-fill" style="width: {{xpProgress}}%"></view>      
        </view>
      </view>

      <view class="stat-divider"></view>

      <view class="stat-row">
        <view class="stat-item">
          <view class="stat-icon today-icon">📖</view>
          <text class="stat-number">{{todayCount}}</text>
          <text class="stat-label">今日学习</text>
        </view>
        <view class="stat-item">
          <view class="stat-icon total-icon">📚</view>
          <text class="stat-number">{{totalCount}}</text>
          <text class="stat-label">已学单词</text>
        </view>
      </view>

      <view class="stat-divider"></view>

      <view class="checkin-row">
        <view class="checkin-item">
          <view class="checkin-icon">🔥</view>
          <view class="checkin-content">
            <text class="checkin-days">{{continuousDays}}</text>
            <text class="checkin-label">连续打卡天数</text>
          </view>
        </view>
      </view>

      <view class="stat-divider"></view>

      <!-- 待复习区域 -->
      <view class="review-row" bindtap="startReview">
        <view class="review-item">
          <view class="review-icon">🔄</view>
          <view class="review-content">
            <text class="review-count">{{pendingReviewCount}}</text>
            <text class="review-label">待复习单词</text>
          </view>
        </view>
      </view>

      <view class="stat-divider"></view>

      <!-- 收藏和错题区域 -->
      <view class="extra-row">
        <view class="extra-item" bindtap="viewCollection">
          <view class="extra-icon">❤️</view>
          <view class="extra-content">
            <text class="extra-count">{{collectedCount}}</text>
            <text class="extra-label">收藏</text>
          </view>
        </view>
        <view class="extra-item" bindtap="viewMistakes">
          <view class="extra-icon">❌</view>
          <view class="extra-content">
            <text class="extra-count">{{mistakeCount}}</text>
            <text class="extra-label">错题</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 欢迎文字区域 -->
  <view class="welcome-section">
    <text class="welcome-text">欢迎来到 WordMaster</text>
    <text class="description">开始你的英语单词学习之旅</text>
  </view>

  <!-- 快捷功能区域 -->
  <view class="quick-section">
    <view class="quick-title">快捷功能</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="startStudy">
        <view class="quick-icon">📖</view>
        <text class="quick-label">开始学习</text>
      </view>
      <view class="quick-item" bindtap="viewWordList">
        <view class="quick-icon">📚</view>
        <text class="quick-label">浏览词库</text>
      </view>
      <view class="quick-item" bindtap="viewCollection">
        <view class="quick-icon">❤️</view>
        <text class="quick-label">收藏夹</text>
      </view>
      <view class="quick-item" bindtap="viewMistakes">
        <view class="quick-icon">❌</view>
        <text class="quick-label">错题本</text>
      </view>
      <view class="quick-item" bindtap="viewStats">
        <view class="quick-icon">📊</view>
        <text class="quick-label">学习统计</text>
      </view>
    </view>
  </view>

  <!-- 词库浏览入口卡片 -->
  <view class="library-card" bindtap="viewWordList">
    <view class="library-card-header">
      <view class="library-card-icon">📚</view>
      <view class="library-card-info">
        <text class="library-card-title">当前词库</text>
        <text class="library-card-name">{{currentLibrary}}</text>
      </view>
    </view>
    <view class="library-card-body">
      <view class="library-card-stats">
        <text class="library-card-count">{{totalWords}}</text>
        <text class="library-card-label">词</text>
      </view>
      <view class="library-card-action">
        <text class="library-card-btn">浏览全部</text>
        <text class="library-card-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 按钮区域 -->
  <view class="btn-section">
    <button class="start-btn" bindtap="startStudy">开始学习</button>
    <button class="review-btn" bindtap="startReview">开始复习</button>        
    <button class="stats-btn" bindtap="viewStats">学习统计</button>
  </view>
</view>