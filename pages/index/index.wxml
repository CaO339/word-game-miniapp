<!--首页 WXML-->
<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">WM</view>
    <text class="app-name">WordMaster</text>
  </view>

  <!-- 统计卡片区域 -->
  <view class="stats-section">
    <view class="stats-card">
      <!-- 等级显示 -->
      <view class="level-row">
        <view class="level-badge">
          <text class="level-text">Lv{{currentLevel}}</text>
        </view>
      </view>
      
      <!-- 经验值进度条 -->
      <view class="xp-row">
        <view class="xp-info">
          <text class="xp-current">{{currentXp}}</text>
          <text class="xp-separator">/</text>
          <text class="xp-max">{{maxXp}}</text>
        </view>
        <view class="xp-bar-container">
          <view class="xp-bar-fill" style="width: {{xpProgress}}%"></view>
        </view>
      </view>

      <view class="stat-divider"></view>
      
      <view class="stat-row">
        <view class="stat-item">
          <view class="stat-icon today-icon">📚</view>
          <text class="stat-number">{{todayCount}}</text>
          <text class="stat-label">今日练习</text>
        </view>
        <view class="stat-item">
          <view class="stat-icon total-icon">📖</view>
          <text class="stat-number">{{totalCount}}</text>
          <text class="stat-label">已学单词</text>
        </view>
      </view>
      
      <view class="stat-divider"></view>
      
      <view class="checkin-row">
        <view class="checkin-item">
          <view class="checkin-icon">🔥</view>
          <view class="checkin-content">
            <text class="checkin-days">{{continuousDays}}</text>
            <text class="checkin-label">连续打卡天数</text>
          </view>
        </view>
      </view>

      <view class="stat-divider"></view>
      
      <!-- 待复习区域 -->
      <view class="review-row">
        <view class="review-item">
          <view class="review-icon">🔄</view>
          <view class="review-content">
            <text class="review-count">{{pendingReviewCount}}</text>
            <text class="review-label">待复习单词</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 欢迎文字区域 -->
  <view class="welcome-section">
    <text class="welcome-text">欢迎来到 WordMaster</text>
    <text class="description">开始你的英语单词学习之旅</text>
  </view>

  <!-- 按钮区域 -->
  <view class="btn-section">
    <button class="start-btn" bindtap="startStudy">开始学习</button>
    <button class="review-btn" bindtap="startReview">开始复习</button>
    <button class="stats-btn" bindtap="viewStats">学习统计</button>
  </view>
</view>
