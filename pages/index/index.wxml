<!--首页 WXML-->
<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">WM</view>
    <text class="app-name">WordMaster</text>
  </view>

  <!-- 词库选择区域 -->
  <view class="library-section">
    <view class="library-header">
      <view class="library-title">选择词库</view>
      <view class="library-more" bindtap="goToLibrary">
        <text>管理</text>
        <text class="more-icon">→</text>
      </view>
    </view>

    <!-- 固定词库 -->
    <view class="library-list">
      <view 
        wx:for="{{fixedLibraries}}" 
        wx:key="key"
        class="library-item {{selectedLibrary === item.key ? 'active' : ''}}" 
        bindtap="switchLibrary" 
        data-library="{{item.key}}" 
      >
        <text class="library-name">{{item.name}}</text>
        <text class="library-desc">{{item.description}}</text>
      </view>
    </view>

    <!-- 用户词库 -->
    <view wx:if="{{customLibraries.length > 0}}" class="custom-library-section">
      <view class="custom-library-title">📁 用户词库</view>
      <view class="library-list">
        <view 
          wx:for="{{customLibraries}}" 
          wx:key="key"
          class="library-item custom {{selectedLibrary === item.key ? 'active' : ''}}" 
          bindtap="switchLibrary" 
          data-library="{{item.key}}" 
        >
          <text class="library-name">{{item.name}}</text>
          <text class="library-desc">{{item.wordCount}} 个单词</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 统计卡片区域 -->
  <view class="stats-section">
    <view class="stats-card">
      <!-- 每日目标区域 -->
      <view class="target-row">
        <view class="target-item {{targetIsCompleted ? 'completed' : ''}}" bindtap="changeTarget">
          <view class="target-icon">{{targetIsCompleted ? '🎯' : '📍'}}</view>
          <view class="target-content">
            <text class="target-label">今日目标</text>
            <text class="target-value">{{targetIsCompleted ? '已完成' : targetTodayNewCount + '/' + target}}</text>
          </view>
          <view class="target-edit-icon">✏️</view>
        </view>
      </view>

      <view class="stat-divider"></view>
      
      <!-- 学习进度区域 -->
      <view class="progress-row">
        <view class="progress-item" bindtap="viewLibrary">
          <view class="progress-icon">📚</view>
          <view class="progress-content">
            <text class="progress-label">词库进度</text>
            <text class="progress-value">{{learnedCount}}/{{totalWords}}</text>
          </view>
        </view>
        <view class="progress-info">
          <text class="progress-remaining">剩余 {{remainingCount}} 个单词</text>
        </view>
      </view>

      <view class="stat-divider"></view>
      
      <!-- 等级显示 -->
      <view class="level-row">
        <view class="level-badge">
          <text class="level-text">Lv{{currentLevel}}</text>
        </view>
      </view>
      
      <!-- 经验值进度条 -->
      <view class="xp-row">
        <view class="xp-info">
          <text class="xp-current">{{currentXp}}</text>
          <text class="xp-separator">/</text>
          <text class="xp-max">{{maxXp}}</text>
        </view>
        <view class="xp-bar-container">
          <view class="xp-bar-fill" style="width: {{xpProgress}}%"></view>
        </view>
      </view>

      <view class="stat-divider"></view>

      <!-- 学习统计区域 -->
      <view class="stats-row">
        <view class="stat-item" bindtap="viewStats">
          <view class="stat-icon">📅</view>
          <view class="stat-content">
            <text class="stat-value">{{continuousDays}}</text>
            <text class="stat-label">连续打卡</text>
          </view>
        </view>
        <view class="stat-divider-vertical"></view>
        <view class="stat-item" bindtap="viewReview">
          <view class="stat-icon">🔄</view>
          <view class="stat-content">
            <text class="stat-value">{{pendingReviewCount}}</text>
            <text class="stat-label">待复习</text>
          </view>
        </view>
        <view class="stat-divider-vertical"></view>
        <view class="stat-item" bindtap="viewCollection">
          <view class="stat-icon">❤️</view>
          <view class="stat-content">
            <text class="stat-value">{{collectedCount}}</text>
            <text class="stat-label">收藏</text>
          </view>
        </view>
        <view class="stat-divider-vertical"></view>
        <view class="stat-item" bindtap="viewMistakes">
          <view class="stat-icon">❌</view>
          <view class="stat-content">
            <text class="stat-value">{{mistakeCount}}</text>
            <text class="stat-label">错题</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="actions-section">
    <view class="action-btn primary" bindtap="goStudy">
      <text class="action-icon">📖</text>
      <text class="action-text">开始学习</text>
    </view>
    <view class="action-btn secondary" bindtap="goReview">
      <text class="action-icon">🔄</text>
      <text class="action-text">复习单词</text>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-item active">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">首页</text>
    </view>
    <view class="tab-item" bindtap="goStudy">
      <text class="tab-icon">📖</text>
      <text class="tab-label">学习</text>
    </view>
    <view class="tab-item" bindtap="goReview">
      <text class="tab-icon">🔄</text>
      <text class="tab-label">复习</text>
    </view>
    <view class="tab-item" bindtap="goCollection">
      <text class="tab-icon">❤️</text>
      <text class="tab-label">收藏</text>
    </view>
    <view class="tab-item" bindtap="goStats">
      <text class="tab-icon">📊</text>
      <text class="tab-label">统计</text>
    </view>
  </view>
</view>
