/* PDF导出页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  padding-top: 80rpx;
  box-sizing: border-box;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.header .subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 预览区域 */
.preview-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.preview-header {
  margin-bottom: 20rpx;
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 预览滚动区域 */
.preview-scroll {
  max-height: 800rpx;
  overflow-y: auto;
}

/* PDF页面预览 */
.pdf-preview {
  margin-bottom: 30rpx;
}

.pdf-preview:last-child {
  margin-bottom: 0;
}

.pdf-page {
  background: #ffffff;
  border-radius: 10rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

/* 页面页眉 */
.page-header {
  text-align: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.page-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.page-date {
  font-size: 22rpx;
  color: #999;
}

/* 页面内容 */
.page-content {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

/* 列 */
.column {
  flex: 1;
  width: 48%;
}

/* 列通用样式 - 左栏和右栏共用 */
.column .column-header {
  display: flex;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #ddd;
  margin-bottom: 15rpx;
}

.column .col-no {
  width: 60rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #666;
  flex-shrink: 0;
}

.column .col-word {
  flex: 1;
  font-size: 20rpx;
  font-weight: bold;
  color: #666;
  text-align: left;
  padding-left: 10rpx;
}

.column .col-meaning {
  flex: 1;
  font-size: 20rpx;
  font-weight: bold;
  color: #666;
  text-align: left;
  padding-left: 10rpx;
}

.column .word-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.column .word-item {
  display: flex;
  align-items: center;
}

.column .item-no {
  width: 60rpx;
  font-size: 22rpx;
  color: #333;
  flex-shrink: 0;
}

.column .item-word {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  padding-left: 10rpx;
  min-width: 0;
}

.column .item-meaning {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  padding-left: 10rpx;
  word-break: break-all;
  min-width: 0;
}

/* 空白横线 - 固定长度 */
.column .item-blank-line {
  flex: 1;
  height: 32rpx;
  border-bottom: 2rpx dashed #333;
  margin-left: 10rpx;
  min-width: 150rpx;
}

/* 左栏特殊样式 - 英译中默写区 */
.left-column .item-blank-line {
  flex: 1;
}

/* 右栏特殊样式 - 中译英默写区 */
.right-column .item-blank-line {
  flex: 1;
}

/* 列分隔线 */
.column-divider {
  width: 1rpx;
  background: #eee;
  margin: 0 15rpx;
}

/* 页面页脚 */
.page-footer {
  text-align: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #eee;
}

.page-number {
  font-size: 20rpx;
  color: #999;
}

/* 操作按钮区域 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.action-btn.outline {
  background: transparent;
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 提示信息 */
.tips-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 25rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 15rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

/* 排序选择区域 */
.sort-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.sort-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sort-icon {
  font-size: 32rpx;
}

.sort-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50rpx;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.sort-value {
  font-size: 26rpx;
}

.sort-arrow {
  font-size: 20rpx;
  opacity: 0.8;
}

/* 排序选择面板 */
.sort-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.sort-panel-content {
  width: 600rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.sort-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.sort-panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.sort-panel-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.sort-options {
  padding: 20rpx;
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 20rpx;
  border-radius: 10rpx;
  transition: background 0.2s;
}

.sort-option:active,
.sort-option.active {
  background: rgba(102, 126, 234, 0.1);
}

.option-label {
  font-size: 28rpx;
  color: #333;
}

.option-check {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

/* 排序信息 */
.page-sort-info {
  text-align: center;
  margin-bottom: 15rpx;
}

.sort-info-text {
  font-size: 20rpx;
  color: #999;
}

/* 错误状态 */
.error-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 20rpx;
}

.error-message {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 40rpx;
}

.error-btn {
  width: 300rpx;
  height: 90rpx;
  line-height: 90rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.tip-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}