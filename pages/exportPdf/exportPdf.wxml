<!-- PDF导出页面 -->
<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <text class="title">{{title}}</text>
    <text class="subtitle" wx:if="wordCount > 0">共 {{wordCount}} 个单词，{{totalPages}} 页</text>
  </view>

  <!-- 排序选择区域 -->
  <view class="sort-section" wx:if="wordCount > 0">
    <view class="sort-label">
      <text class="sort-icon">🔄</text>
      <text class="sort-text">排序方式：</text>
    </view>
    <button class="sort-btn" bindtap="showSortPanel">
      <text class="sort-value">{{sortBy === 'alphabet_asc' ? '按字母排序（A-Z）' : sortBy === 'time_desc' ? '按学习时间排序（最新优先）' : sortBy === 'time_asc' ? '按学习时间排序（最早优先）' : sortBy === 'wrongCount_desc' ? '按错误次数排序' : sortBy === 'collectTime_desc' ? '按收藏时间排序（最新优先）' : '选择排序'}}</text>
      <text class="sort-arrow">▼</text>
    </button>
  </view>

  <!-- 排序选择面板 -->
  <view class="sort-panel" wx:if="{{showSortPanel}}" bindtap="showSortPanel">
    <view class="sort-panel-content" catchtap="stopPropagation">
      <view class="sort-panel-header">
        <text class="sort-panel-title">选择排序方式</text>
        <text class="sort-panel-close" bindtap="showSortPanel">✕</text>
      </view>
      <view class="sort-options">
        <view 
          class="sort-option {{sortBy === option.value ? 'active' : ''}}" 
          wx:for="{{sortOptions}}" 
          wx:key="value"
          bindtap="selectSort"
          data-value="{{option.value}}"
        >
          <text class="option-label">{{option.label}}</text>
          <text class="option-check" wx:if="{{sortBy === option.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 错误状态 -->
  <view class="error-section" wx:if="{{showError}}">
    <view class="error-icon">⚠️</view>
    <text class="error-title">数据异常</text>
    <text class="error-message">{{errorMessage}}</text>
    <button class="error-btn" bindtap="goBack">返回</button>
  </view>

  <!-- 预览区域 -->
  <view class="preview-section" wx:if="wordCount > 0">
    <view class="preview-header">
      <text class="preview-title">📄 PDF预览</text>
    </view>
    
    <!-- PDF内容预览 -->
    <scroll-view class="preview-scroll" scroll-y>
      <view class="pdf-preview" wx:for="{{pages}}" wx:key="index">
        <view class="pdf-page">
          <!-- 页眉 -->
          <view class="page-header">
            <text class="page-title">{{title}}</text>
            <text class="page-date">{{exportDate}}</text>
          </view>
          
          <!-- 排序信息 -->
          <view class="page-sort-info">
            <text class="sort-info-text">排序方式：{{sortBy === 'alphabet_asc' ? '按字母排序' : sortBy === 'time_desc' ? '按学习时间排序（最新优先）' : sortBy === 'time_asc' ? '按学习时间排序（最早优先）' : sortBy === 'wrongCount_desc' ? '按错误次数排序' : sortBy === 'collectTime_desc' ? '按收藏时间排序（最新优先）' : '未知排序'}}</text>
          </view>
          
          <!-- 内容区域 -->
          <view class="page-content">
            <!-- 左栏（英译中默写区） -->
            <view class="column left-column">
              <view class="column-header">
                <text class="col-no">NO.</text>
                <text class="col-word">Vocabulary</text>
                <text class="col-meaning">Meaning</text>
              </view>
              <view class="word-list">
                <view class="word-item" wx:for="{{item.leftColumn}}" wx:key="index">
                  <text class="item-no">{{item.no}}</text>
                  <text class="item-word">{{item.word}}</text>
                  <view class="item-blank-line"></view>
                </view>
              </view>
            </view>
            
            <!-- 分隔线 -->
            <view class="column-divider"></view>
            
            <!-- 右栏（中译英默写区） -->
            <view class="column right-column">
              <view class="column-header">
                <text class="col-no">NO.</text>
                <text class="col-word">Vocabulary</text>
                <text class="col-meaning">Meaning</text>
              </view>
              <view class="word-list">
                <view class="word-item" wx:for="{{item.rightColumn}}" wx:key="index">
                  <text class="item-no">{{item.no}}</text>
                  <view class="item-blank-line"></view>
                  <text class="item-meaning">{{item.meaning}}</text>
                </view>
              </view>
            </view>
          </view>
          
          <!-- 页脚 -->
          <view class="page-footer">
            <text class="page-number">第{{item.pageNum}}页 / 共{{totalPages}}页</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section" wx:if="wordCount > 0">
    <button class="action-btn primary" bindtap="sharePdf">📤 分享PDF</button>
    <button class="action-btn secondary" bindtap="copyContent">📋 复制内容</button>
    <button class="action-btn outline" bindtap="goBack">返回</button>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section" wx:if="wordCount > 0">
    <text class="tips-title">💡 提示</text>
    <view class="tips-list">
      <text class="tip-item">• 左侧：英译中默写（看英文写中文）</text>
      <text class="tip-item">• 右侧：中译英默写（看中文写英文）</text>
      <text class="tip-item">• 重复单词已自动去重</text>
      <text class="tip-item">• 每页显示20个单词</text>
    </view>
  </view>
</view>