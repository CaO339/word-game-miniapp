/* 统计页面样式 - 统一风格 */

.container {
  min-height: 100vh;
  /* 统一主色调：紫色渐变 */
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  padding-top: 80rpx;
  box-sizing: border-box;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-decoration {
  width: 200rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 5rpx;
  margin: 20rpx auto 0;
}

/* 区块 */
.section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.section-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 统计网格 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  min-width: calc(50% - 10rpx);
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 25rpx;
  text-align: center;
}

.stat-card.highlight {
  background: rgba(255, 215, 0, 0.2);
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value.fire {
  color: #ff6b6b;
}

.stat-value.pending {
  color: #ffd93d;
}

.stat-value.completed {
  color: #6bcb77;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 等级卡片 */
.level-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
}

.level-info {
  text-align: center;
  margin-bottom: 25rpx;
}

.level-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 10rpx;
}

.level-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffd93d;
}

.xp-info {
  text-align: center;
}

.xp-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 15rpx;
}

.xp-bar-container {
  width: 100%;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.xp-bar {
  height: 100%;
  background: linear-gradient(90deg, #ffd93d, #ff6b6b);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.xp-text {
  font-size: 26rpx;
  color: #ffffff;
}

/* 周趋势图表 */
.weekly-chart {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-container {
  width: 40rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.bar {
  width: 100%;
  background: linear-gradient(180deg, #667eea, #764ba2);
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  transition: height 0.5s ease;
}

.bar-value {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: bold;
  margin-top: 5rpx;
}

.bar-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 5rpx;
}

.bar-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 底部区域 */
.footer {
  text-align: center;
}

.back-btn {
  width: 300rpx;
  height: 100rpx;
  line-height: 100rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.back-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
